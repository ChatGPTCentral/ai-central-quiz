BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=pub_685dd277-3d37-4105-9320-d248c9e28f76
APOLLO_API_KEY=your_apollo_api_key_here
NEXT_PUBLIC_SITE_URL=https://quiz.thecentral.ai
# Origin of the ai-central-library app. /result CTAs route through
# ${NEXT_PUBLIC_LIBRARY_URL}/login?next=/pricing&email=… so buyers land
# in the library's signup → Stripe checkout flow (instead of a bare
# Stripe payment link that left them with no gated access).
NEXT_PUBLIC_LIBRARY_URL=https://app.thecentral.ai
# Shared secret with the ai-central-library. The library HMAC-signs
# POST /api/beehiiv/sync-stage bodies with this; we verify on receive.
# Generate: openssl rand -hex 32
LIBRARY_GRADUATE_SECRET=
# Optional — enables AI assist ("Rewrite label" / "Suggest options") in /admin/editor.
# Leave unset to disable AI assist; everything else in the editor works without it.
ANTHROPIC_API_KEY=
# Optional — enables admin email notifications when a new quiz is submitted.
# Get a key at https://resend.com (free tier: 100/day). Leave RESEND_API_KEY
# unset to disable email — submissions still process; a "would send" line is
# logged so you can verify the wiring without paying for a service.
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=chatgptcentral@gmail.com
ADMIN_NOTIFY_FROM=AI Central <onboarding@resend.dev>
# Optional — powers the result-page "Explore the library" search + suggestions
# from the AI Central document database in Notion. Leave unset to hide search
# results (the section still renders, just empty). NOTION_DOCS_DATABASE_ID may
# be a database id or a data source id. Property names default to
# Summary / URL / Tags; override if your DB uses different ones.
NOTION_API_KEY=
NOTION_DOCS_DATABASE_ID=
NOTION_PROP_SUMMARY=Summary
NOTION_PROP_URL=URL
NOTION_PROP_TAGS=Tags

# Behavior analytics (Microsoft Clarity) — heatmaps + session recordings.
# Create a free project at clarity.microsoft.com and paste its project id.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Experimentation engine master flag (per-experiment kill lives in admin).
NEXT_PUBLIC_EXPERIMENTS_ENABLED=
